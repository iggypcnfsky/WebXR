{
  "name": "sketchar-webxr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "next-upload-api"
  ],
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n vite,api -c cyan,magenta \"npm run dev\" \"npm run upload-api:dev\"",
    "build": "vite build",
    "build:vercel": "vite build && node next-upload-api/scripts/sync-vite-dist.mjs && npm run build -w next-upload-api",
    "upload-api:dev": "npm run dev --prefix next-upload-api"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "concurrently": "^9.1.2",
    "vite": "^8.0.3",
    "vite-plugin-restart": "^0.4.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "lucide": "^1.7.0",
    "three": "^0.166.1",
    "vite-plugin-glsl": "^1.3.0"
  }
}
