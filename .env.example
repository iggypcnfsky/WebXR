# Copy to .env.local at this repo root. Restart Vite + Next after edits.
#
# --- Vercel (required for /api/export-glb on the same host as the viewer)
# In Project → Settings → General:
#   Root Directory: next-upload-api   (NOT repo root — if Root is ".", Vercel uses the Vite
#   preset, publishes only dist/, and /api/export-glb returns 404.)
#   Framework Preset: Next.js (auto-detected from this folder once Root Directory is set)
#   Enable "Include files outside the root directory in the Build Step" so `cd ..` works.
# Build/Install are defined in next-upload-api/vercel.json (`cd .. && npm run build:vercel`).
# That script runs everything: `vite build` → sync dist → `public/` → `next build` (not Next-only).
# Set the same env keys below in Project → Environment Variables (incl. VITE_* for the client bundle).

# --- Vite (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_EXPORT_GLB_URL=/api/export-glb
# Must be the EXACT same string as EXPORT_UPLOAD_TOKEN below (long random secret, not a URL).
# Used for POST (upload) and DELETE (remove room GLB from R2 when deleted from the scene).
VITE_EXPORT_GLB_TOKEN=

# --- Next upload API (server — not VITE_*)
# Must match VITE_EXPORT_GLB_TOKEN exactly.
EXPORT_UPLOAD_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sketchar
# Public base URL for R2 objects (no trailing slash). Required for viewer/Quest to load dropped or referenced GLB assets via HTTPS after upload.
PUBLIC_R2_READ_URL=

# --- Walden-style GLB optimize (POST /api/export-glb compresses before R2 upload)
# WALDEN_GLB_TEXTURE_MAX_EDGE=1024
# WALDEN_GLB_WEBP_QUALITY=78
# WALDEN_GLB_MAX_UPLOAD_MB=100
